# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Monitor — environment variables (EXAMPLE)
# Copiar a `.env` y rellenar. NUNCA commitear el `.env` real (perms 600).
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
ENV=dev                          # dev | prod
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
TZ=Europe/Rome

# ── Analítica (booleano) ─────────────────────────────────────────────────────
# `analytics` = levanta Metabase + Superset ya inicializados. Vacío = apagado.
COMPOSE_PROFILES=analytics

# ── Postgres / TimescaleDB ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# URL derivada (usada por la app). Ajustar si se cambia algo de arriba.
DATABASE_URL=postgresql://portfolio:CHANGE_ME_strong_password@postgres:5432/portfolio
# Usuario de SOLO LECTURA para dashboards (Grafana/Metabase/Superset) — §8.
POSTGRES_RO_USER=verdict_ro
POSTGRES_RO_PASSWORD=CHANGE_ME_ro_password

# ── Finnhub (precios + fundamentals + news) ──────────────────────────────────
# La misma key alimenta el price poller Y los fundamentals del §5.3
# (provider FinnhubFundamentalsProvider sobre /stock/metric).
FINNHUB_API_KEY=CHANGE_ME
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ── Price poller ─────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60                 # pausa entre barridos completos
FINNHUB_REQUEST_SPACING_SECONDS=1.1      # espaciado entre requests (free ~60/min)
HOLDINGS_SYNC_EVERY_TICKS=60             # sync de posiciones IBKR cada N ticks (0=off)

# ── Fundamentals autoritativos (US) — OPCIONALES ─────────────────────────────
# El chequeo de tesis (§5.3) usa Finnhub por defecto (ver arriba). EDGAR/FMP
# quedan como providers alternativos. OJO: no poner comentarios inline en líneas
# vacías (KEY=  # comentario) — el parser toma el comentario como valor.
# SEC EDGAR requiere User-Agent identificable (email de contacto).
SEC_EDGAR_USER_AGENT=Portfolio Monitor guillermo.gregoret@example.com
# Provider alternativo de fundamentals (§13). Dejar vacío si se usa Finnhub.
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api/v3
# Frescura del snapshot: al gatillar, refetchea si el último es más viejo (horas).
FUNDAMENTALS_MAX_AGE_HOURS=24
# Deterioro de la tesis (§5.3): refresca held names cada N ticks para armar el
# historial, y avisa si el último snapshot empeora vs un baseline ≥ N días.
FUNDAMENTALS_REFRESH_EVERY_TICKS=720     # ~cada 12h con tick de 60s (0=off)
FUNDAMENTALS_BASELINE_MIN_AGE_DAYS=45    # antigüedad mínima del baseline a comparar
FUNDAMENTALS_DECAY_COOLDOWN_DAYS=30      # 1 aviso de deterioro por ticker / N días
FUND_REVENUE_GROWTH_DROP_PP=15           # caída del crecimiento que dispara (puntos %)
FUND_MARGIN_DROP_PP=5                    # compresión del margen bruto (puntos %)
FUND_DEBT_RISE=0.5                       # salto de deuda/equity (ratio absoluto)

# ── Earnings + avisos semanales (§5) ─────────────────────────────────────────
EARNINGS_REFRESH_EVERY_TICKS=1440        # refresca el calendario cada N ticks (0=off)
EARNINGS_HORIZON_DAYS=120                # días hacia adelante a traer
# Rating de analistas (§5): avisa si el consenso (escala 1-5) se mueve ≥ umbral.
RATINGS_REFRESH_EVERY_TICKS=1440         # refresca el consenso cada N ticks (0=off)
RATINGS_BASELINE_MIN_AGE_DAYS=30         # antigüedad mínima del baseline a comparar
RATINGS_SHIFT_THRESHOLD=0.3              # cambio de score que dispara
RATINGS_COOLDOWN_DAYS=30                 # 1 aviso de cambio por ticker / N días
# Digests semanales (hora de mercado, America/New_York):
WEEKLY_DIGESTS_ENABLED=true
DIGEST_MONDAY_HOUR_ET=8                  # lunes: earnings de la semana ~08:00 ET (pre-apertura)
DIGEST_FRIDAY_HOUR_ET=16                 # viernes: resumen del portfolio ~16:00 ET (cierre)

# ── DCA (§5.4) — monto sugerido en dips, capado al cash de la cuenta ──────────
DCA_ENABLED=true
DCA_DEFAULT_TRANCHE_USD=100              # monto base si el ticker no tiene plan propio (tabla dca_plan)
DCA_MAX_MULTIPLIER=2.0                   # tope del factor por profundidad del dip
DCA_DIP_SLOPE=0.1                        # +multiplicador por cada 1% de caída (-3% → x1.3)

# ── Cobertura europea (fase 2) ───────────────────────────────────────────────
# opcional, fase 2 (defensa EUR)
EODHD_API_KEY=

# ── Anthropic (razonamiento) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-8

# ── Telegram (notificaciones) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
# Bot interactivo /status (§5). 🔴 FAIL-CLOSED: sin tu user id acá, el bot no
# responde datos a nadie (solo /whoami, que te dice tu id para completar esto).
TELEGRAM_BOT_ENABLED=true
TELEGRAM_ALLOWED_USER_IDS=            # CSV de tu(s) user id(s) personales, ej: 123456789

# ── IB Gateway (READ-ONLY) ───────────────────────────────────────────────────
# 🔴 READ_ONLY_API SIEMPRE en 'yes'. El sistema jamás ejecuta órdenes.
IB_GATEWAY_HOST=ib-gateway
# La imagen gnzsnz/ib-gateway publica la API a otros contenedores vía socat:
# 4004 = paper, 4003 = live (4001/4002 quedan en el localhost del contenedor).
IB_GATEWAY_PORT=4004
IB_GATEWAY_CLIENT_ID=1           # clientId de la conexión API (read-only)
IB_ACCOUNT_IA=U22106929
IB_ACCOUNT_SALUD_DEFENSA=U26716079
# Credenciales IBKR (las consume la imagen ib-gateway, no la app)
TWS_USERID=CHANGE_ME
TWS_PASSWORD=CHANGE_ME
TRADING_MODE=paper               # paper | live
READ_ONLY_API=yes                # 🔴 NO cambiar a 'no'
IB_GATEWAY_AUTO_RESTART_TIME=11:59 PM

# ── Monitoreo ────────────────────────────────────────────────────────────────
# Uptime Kuma: kuma-init crea el admin y los monitores con estos valores.
KUMA_ADMIN_USER=admin
KUMA_ADMIN_PASSWORD=CHANGE_ME
# Token del monitor push (dead-man's switch). Alfanumérico, ~16 chars.
KUMA_PUSH_TOKEN=CHANGE_ME_16_chars
# La app pinga esta URL cada loop; si deja de pingear → alerta de Kuma.
# Debe terminar con el MISMO token de arriba (env_file no interpola variables).
HEALTHCHECKS_PING_URL=http://uptime-kuma:3001/api/push/CHANGE_ME_16_chars

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Metabase (perfil analytics) ──────────────────────────────────────────────
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=CHANGE_ME

# ── Superset (perfil analytics) ──────────────────────────────────────────────
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME
# Clave de firma de sesiones/cookies. Larga y aleatoria (openssl rand -base64 42).
SUPERSET_SECRET_KEY=CHANGE_ME_long_random_secret
